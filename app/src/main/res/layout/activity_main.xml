<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎮 NatProxy"
            android:textSize="32sp"
            android:textColor="#58A6FF"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SOCKS5 پروکسی برای کنسول"
            android:textSize="14sp"
            android:textColor="#8B949E"
            android:layout_marginBottom="24dp"/>

        <!-- Status card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#161B22"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="وضعیت"
                android:textColor="#8B949E"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏸ متوقف"
                android:textColor="#8B949E"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvIp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IP: در حال شناسایی..."
                android:textColor="#58A6FF"
                android:textSize="13sp"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Config card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#161B22"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="آدرس IP"
                android:textColor="#8B949E"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etHost"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="192.168.1.x"
                    android:textColor="#E6EDF3"
                    android:textColorHint="#484F58"
                    android:background="#0D1117"
                    android:padding="10dp"
                    android:inputType="text"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnDetect"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="شناسایی"
                    android:textSize="12sp"
                    android:backgroundTint="#21262D"
                    android:textColor="#58A6FF"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="پورت"
                android:textColor="#8B949E"
                android:textSize="12sp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etPort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="9898"
                android:textColor="#E6EDF3"
                android:background="#0D1117"
                android:padding="10dp"
                android:inputType="number"/>
        </LinearLayout>

        <!-- Toggle button -->
        <Button
            android:id="@+id/btnToggle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="▶ شروع پروکسی"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#238636"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp"/>

        <!-- Hint box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#161B22"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 راهنمای تنظیم کنسول"
                android:textColor="#E6EDF3"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="۱. پروکسی را شروع کنید\n۲. در کنسول بخش Network Settings بروید\n۳. نوع Proxy را Manual انتخاب کنید\n۴. آدرس IP و پورت ۹۸۹۸ را وارد کنید\n۵. تست اتصال را انجام دهید"
                android:textColor="#8B949E"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4"/>
        </LinearLayout>

        <!-- Log -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#161B22"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="لاگ"
                android:textColor="#8B949E"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="منتظر شروع..."
                android:textColor="#3FB950"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.4"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
